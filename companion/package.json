{
  "name": "@affectively/zedge-companion",
  "version": "5.0.0",
  "description": "Zedge companion sidecar \u2014 inference bridge + compute pool node",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "mcp": "bun run src/mcp-stdio.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "build:mcp": "bun build src/mcp-stdio.ts --outdir dist --target bun --minify"
  },
  "dependencies": {
    "yjs": "^13.6.0",
    "@dashrelay/client": "workspace:*",
    "@affectively/auth": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.23.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "typescript": "^5.9.0"
  },
  "author": "AFFECTIVELY <support@affectively.ai>",
  "license": "MIT"
}
